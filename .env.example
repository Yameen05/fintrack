# Copy this file to .env for local development.
# Never commit .env. Generate fresh production values before deployment.

# Database
DB_HOST=db
DB_USERNAME=root
DB_PASSWORD=change-me-local-db-password

# Backend auth
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret

# OpenAI insights (optional; leave blank to disable paid AI calls)
OPENAI_API_KEY=

# Plaid bank connections (optional for manual transaction tracking)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_WEBHOOK_URL=

# AES-256-GCM key used to encrypt Plaid access tokens at rest.
# Generate with: openssl rand -base64 32
PLAID_ENCRYPTION_KEY=replace-with-openssl-rand-base64-32

# Comma-separated origins allowed to call the API.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
